<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimOpt.Visualization.ViewModels"
        xmlns:controls="using:SimOpt.Visualization.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="520"
        x:Class="SimOpt.Visualization.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SimOpt Visualization"
        Width="960" Height="520"
        MinWidth="700" MinHeight="400"
        Background="#161620">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Control bar -->
        <Border DockPanel.Dock="Bottom" Background="#1C1C2A" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <Button Content="Start" Command="{Binding StartCommand}"
                        IsEnabled="{Binding !IsRunning}"
                        Padding="20,6" FontSize="13" FontWeight="SemiBold"/>
                <Button Content="Stop" Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Padding="20,6" FontSize="13"/>

                <Border Width="1" Background="#333345" Margin="4,2"/>

                <Button Content="Faster" Command="{Binding FasterCommand}"
                        Padding="12,6" FontSize="12"/>
                <TextBlock Text="{Binding Speed, StringFormat='{}{0}ms'}"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="#8888A4" FontFamily="Cascadia Mono, Consolas, monospace"
                           Width="45" TextAlignment="Center"/>
                <Button Content="Slower" Command="{Binding SlowerCommand}"
                        Padding="12,6" FontSize="12"/>

                <Border Width="1" Background="#333345" Margin="4,2"/>

                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                           Foreground="#7777A0" FontSize="12" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Canvas -->
        <controls:SimulationCanvas x:Name="SimCanvas"/>
    </DockPanel>
</Window>
