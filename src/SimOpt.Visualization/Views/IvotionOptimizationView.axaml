<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimOpt.Visualization.ViewModels"
             xmlns:views="using:SimOpt.Visualization.Views"
             xmlns:ivo="using:SimOpt.Ivotion"
             xmlns:scottplot="using:ScottPlot.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="540"
             x:Class="SimOpt.Visualization.Views.IvotionOptimizationView"
             x:DataType="vm:IvotionOptimizationViewModel"
             Background="#161620">

    <Grid Margin="12" ColumnDefinitions="320,*" RowDefinitions="*">

        <!-- Configuration panel -->
        <Border Grid.Column="0" Background="#1C1C2A" CornerRadius="6" Padding="14" Margin="0,0,8,0">
            <StackPanel Spacing="10">

                <TextBlock Text="IVOTION OPTIMIZATION" FontSize="12" FontWeight="Bold"
                           Foreground="#8888A4" Margin="0,0,0,6"/>

                <TextBlock Text="Objective" FontSize="11" Foreground="#8888A4"/>
                <ComboBox ItemsSource="{Binding Objectives}"
                          SelectedItem="{Binding SelectedObjective}"
                          IsEnabled="{Binding !IsRunning}"
                          HorizontalAlignment="Stretch" FontSize="12"/>

                <TextBlock Text="Strategy" FontSize="11" Foreground="#8888A4" Margin="0,6,0,0"/>
                <ComboBox ItemsSource="{Binding Strategies}"
                          SelectedValue="{Binding SelectedStrategy}"
                          SelectedValueBinding="{Binding Kind}"
                          IsEnabled="{Binding !IsRunning}"
                          HorizontalAlignment="Stretch" FontSize="12">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:IvotionStrategyOption">
                            <TextBlock Text="{Binding DisplayName}"
                                       IsEnabled="{Binding IsEnabled}"
                                       Opacity="{Binding IsEnabled, Converter={x:Static views:BoolToOpacityConverter.Instance}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Operator wage ($/hr)" FontSize="11" Foreground="#8888A4" Margin="0,6,0,0"/>
                <NumericUpDown Value="{Binding OperatorWage}" Minimum="0" Maximum="200" Increment="1"
                               FormatString="0.00" IsEnabled="{Binding !IsRunning}"/>

                <TextBlock Text="{Binding Iterations, StringFormat='Iterations: {0}'}"
                           FontSize="11" Foreground="#8888A4" Margin="0,6,0,0"/>
                <Slider Value="{Binding Iterations}" Minimum="5" Maximum="200" TickFrequency="5"
                        IsSnapToTickEnabled="True" IsEnabled="{Binding !IsRunning}"/>

                <TextBlock Text="{Binding PopulationSize, StringFormat='Population (EA): {0}'}"
                           FontSize="11" Foreground="#8888A4" Margin="0,6,0,0"/>
                <Slider Value="{Binding PopulationSize}" Minimum="4" Maximum="40" TickFrequency="2"
                        IsSnapToTickEnabled="True" IsEnabled="{Binding !IsRunning}"/>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                    <Button Content="Run" Command="{Binding RunCommand}"
                            Padding="24,8" FontSize="13" FontWeight="SemiBold"
                            Background="#2E8B57" Foreground="White"/>
                    <Button Content="Stop" Command="{Binding StopCommand}"
                            Padding="20,8" FontSize="13"/>
                    <Button Content="Apply to viz" Command="{Binding ApplyToVizCommand}"
                            Padding="14,8" FontSize="12"/>
                </StackPanel>

                <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#7777A0"
                           TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Results pane -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto">

            <Border Grid.Row="0" Background="#1C1C2A" CornerRadius="6" Padding="8">
                <scottplot:AvaPlot x:Name="FitnessPlot"/>
            </Border>

            <Border Grid.Row="1" Background="#1C1C2A" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="BEST SOLUTION" FontSize="11"
                               FontWeight="Bold" Foreground="#8888A4" Margin="0,0,0,6"/>
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="KPIs" FontSize="11"
                               FontWeight="Bold" Foreground="#8888A4" Margin="0,0,0,6"/>

                    <TextBlock Grid.Column="0" Grid.Row="1" FontSize="11" Foreground="#CCCCDD"
                               FontFamily="Cascadia Mono, Consolas, monospace"
                               Text="{Binding BestSolution, Converter={x:Static views:IvotionSolutionToSummaryConverter.Instance}}"/>

                    <TextBlock Grid.Column="1" Grid.Row="1" FontSize="11" Foreground="#CCCCDD"
                               FontFamily="Cascadia Mono, Consolas, monospace"
                               Text="{Binding BestKpis, Converter={x:Static views:IvotionKpisToSummaryConverter.Instance}}"/>

                    <TextBlock Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" FontSize="11"
                               Foreground="#8888A4" Margin="0,8,0,0"
                               Text="{Binding BestFitness, StringFormat='Best fitness: {0:F3}'}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
